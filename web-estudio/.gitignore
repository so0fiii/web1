# .gitignore indica a Git que archivos no debe subir al repositorio.
# Esto es importante para evitar dependencias pesadas, builds generados,
# credenciales locales y archivos temporales.

# Dependencias instaladas por npm/yarn/pnpm.
# Se regeneran con `npm install`, por eso no se versionan.
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Reportes de cobertura de tests.
/coverage

# Carpetas generadas por Next.js.
# `.next` es salida interna de desarrollo/build y `out` se usa en export estatico.
/.next/
/out/

# Carpeta de build generica.
/build

# Archivos del sistema operativo o certificados locales.
.DS_Store
*.pem

# Logs de depuracion de gestores de paquetes.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Variables de entorno.
# Normalmente contienen secretos, tokens o claves privadas y no deben subirse.
.env*

# Configuracion local creada por Vercel CLI.
.vercel

# Cache incremental de TypeScript y archivo generado por Next.js.
*.tsbuildinfo
next-env.d.ts
